{
  "name": "asyncat-oss",
  "version": "0.1.0",
  "description": "Asyncat — open-source AI-powered workspace for teams",
  "type": "module",
  "private": true,
  "workspaces": [
    "den",
    "neko",
    "cli"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "npm run dev -w den & npm run dev -w neko",
    "dev:backend": "npm run dev -w den",
    "dev:frontend": "npm run dev -w neko",
    "start": "npm run start -w den",
    "cli": "node cat",
    "build": "npm run build -w neko"
  },
  "bin": {
    "asyncat": "cat"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
