# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path (default: ./data/asyncat.db)
DB_PATH=./data/asyncat.db

# ─── Solo / Server mode ──────────────────────────────────────────────────────
# SOLO_MODE=true  → auto-creates one user + workspace on first boot (default)
# SOLO_MODE=false → server mode; users register via /api/auth/register
SOLO_MODE=true
SOLO_EMAIL=admin@local
SOLO_PASSWORD=changeme   # ← CHANGE THIS

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Local AI Models ──────────────────────────────────────────────────────────
# Built-in llama-server runs on this port (default: 8765)
# LLAMA_SERVER_PORT=8765
# Directory where downloaded GGUF models are stored (default: ./data/models)
# MODELS_PATH=./data/models

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH on disk (default, no setup needed)
# STORAGE_DRIVER=azure  → uses Azure Blob Storage (set credentials below)
STORAGE_DRIVER=local
STORAGE_PATH=./data/uploads

# Azure credentials (only needed when STORAGE_DRIVER=azure)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# ─── Billing (optional — disabled by default for self-hosted) ─────────────────
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (optional — used for calendar event invites) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Google Calendar (optional, not yet shipped) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
