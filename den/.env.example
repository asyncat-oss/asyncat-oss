# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8716
NODE_ENV=development
FRONTEND_URL=http://localhost:8717
PUBLIC_URL=http://localhost:8716

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path (default: ./data/asyncat.db)
DB_PATH=./data/asyncat.db

# ─── Solo / Server mode ──────────────────────────────────────────────────────
# SOLO_MODE=true  → auto-creates one user + workspace on first boot (default)
# SOLO_MODE=false → server mode; users register via /api/auth/register
SOLO_MODE=true
SOLO_EMAIL=admin@local
SOLO_PASSWORD=changeme

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── AI Provider (recommended: configure via the UI after logging in) ─────────
# These are optional global server-side defaults. Per-user config set in the UI
# takes priority. Leave blank to skip — you can connect your AI provider from
# the Settings page inside the app.
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=
# AI_MODEL=gpt-4o

# ─── Local AI Models ──────────────────────────────────────────────────────────
# Built-in llama-server runs on this port (default: 8765)
# LLAMA_SERVER_PORT=8765
# Directory where downloaded GGUF models are stored (default: ./data/models)
# MODELS_PATH=./data/models

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH on disk (default, no setup needed)
STORAGE_DRIVER=local
STORAGE_PATH=./data/uploads
