# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8716
NODE_ENV=development
FRONTEND_URL=http://localhost:8717
PUBLIC_URL=http://localhost:8716

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path (default: ./data/asyncat.db)
DB_PATH=./data/asyncat.db

# ─── Local account seed ──────────────────────────────────────────────────────
# Used only when a fresh database creates its first account.
# You can change the account name, email, and password in the setup walkthrough.
LOCAL_EMAIL=admin@local
LOCAL_PASSWORD=changeme

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Local AI Models ──────────────────────────────────────────────────────────
# Built-in llama-server runs on this port (default: 8765)
# LLAMA_SERVER_PORT=8765
# Optional explicit llama.cpp server binary. asyncat install --local-engine sets this.
# LLAMA_BINARY_PATH=/full/path/to/llama-server
# Optional Python fallback path. Asyncat's venv fallback sets this.
# LLAMA_PYTHON_PATH=/full/path/to/python
# Directory where downloaded GGUF models are stored (default: ./data/models)
# MODELS_PATH=./data/models

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH on disk (default, no setup needed)
STORAGE_DRIVER=local
STORAGE_PATH=./data/uploads
