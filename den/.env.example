# ─────────────────────────────────────────────────────────────────────────────
# Asyncat backend (den) — bootstrap configuration only.
#
# This file holds just the values the server needs *before* the database is open
# (or to verify auth on every request). Everything else — local AI engine paths
# and ports (llama.cpp / Whisper / Piper / image / MLX), capability providers,
# integration OAuth credentials, mail, and notifications — is now configured
# inside the app and stored in the database (the `app_config` table), then
# hydrated into the environment at boot. Set those in:
#   • Settings → Runtime / Server   (local engines, paths, ports)
#   • Settings → Integrations        (Google, GitHub, Outlook, Obsidian, mail…)
#   • Models page                    (providers, API keys, model downloads)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8716
NODE_ENV=development
FRONTEND_URL=http://localhost:8717
PUBLIC_URL=http://localhost:8716

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path (default: ./data/asyncat.db)
DB_PATH=./data/asyncat.db

# ─── Local account seed ──────────────────────────────────────────────────────
# Used only when a fresh database creates its first account.
# You can change the account name, email, and password in the setup walkthrough.
LOCAL_EMAIL=admin@local
LOCAL_PASSWORD=changeme

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH on disk (default, no setup needed)
STORAGE_DRIVER=local
STORAGE_PATH=./data/uploads
