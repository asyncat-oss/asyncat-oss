# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8716
NODE_ENV=development
FRONTEND_URL=http://localhost:8717
PUBLIC_URL=http://localhost:8716

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path (default: ./data/asyncat.db)
DB_PATH=./data/asyncat.db

# ─── Local account seed ──────────────────────────────────────────────────────
# Used only when a fresh database creates its first account.
# You can change the account name, email, and password in the setup walkthrough.
LOCAL_EMAIL=admin@local
LOCAL_PASSWORD=changeme

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Local AI Models ──────────────────────────────────────────────────────────
# Built-in llama-server runs on this port (default: 8765)
# LLAMA_SERVER_PORT=8765
# Optional explicit llama.cpp server binary. asyncat install --local-engine sets this.
# LLAMA_BINARY_PATH=/full/path/to/llama-server
# Optional Python fallback path. Asyncat's venv fallback sets this.
# LLAMA_PYTHON_PATH=/full/path/to/python
# Directory where downloaded GGUF/MLX/audio models are stored (default: ./data/models)
# Audio models go in: ./data/models/audio/whisper/ and ./data/models/audio/tts/
# MODELS_PATH=./data/models

# ─── Local Audio Models ───────────────────────────────────────────────────────
# Speech-to-Text: whisper.cpp server port (default: 8767)
# WHISPER_SERVER_PORT=8767
# Optional explicit whisper-server binary path (auto-detected if not set)
# WHISPER_BINARY_PATH=/full/path/to/whisper-server

# Text-to-Speech: Piper TTS port (default: 8768, used for future HTTP mode)
# TTS_SERVER_PORT=8768
# Optional explicit piper binary path (auto-detected if not set)
# PIPER_BINARY_PATH=/full/path/to/piper

# ─── Local Image Generation ───────────────────────────────────────────────────
# Default image backend: simple (stable-diffusion.cpp) | comfyui | cloud
# ASYNCAT_IMAGE_PROVIDER=simple
# Optional explicit stable-diffusion.cpp binary path (auto-detected if not set)
# IMAGEGEN_BINARY_PATH=/full/path/to/sd
# Where the ComfyUI image tester looks for a running ComfyUI server
# COMFYUI_BASE_URL=http://127.0.0.1:8188

# ─── Local AI on Apple Silicon (MLX) ──────────────────────────────────────────
# MLX server port (default: 8766)
# MLX_SERVER_PORT=8766
# Directory for downloaded MLX models (default: ./data/models/mlx)
# MLX_MODELS_PATH=./data/models/mlx
# Optional explicit MLX Python path (Asyncat's managed venv sets this)
# MLX_PYTHON_PATH=/full/path/to/python

# ─── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local  → files saved to STORAGE_PATH on disk (default, no setup needed)
STORAGE_DRIVER=local
STORAGE_PATH=./data/uploads

# ─── Integrations ─────────────────────────────────────────────────────────────
# You can set these here or enter them directly in Settings → Integrations.

# Google Calendar — create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Set the authorized redirect URI to: <PUBLIC_URL>/api/integrations/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub — create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: <PUBLIC_URL>/api/integrations/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Microsoft / Outlook Calendar — register an app at https://portal.azure.com
# Set the redirect URI to: <PUBLIC_URL>/api/integrations/outlook/callback
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Obsidian — absolute path to your vault directory (no OAuth needed)
# OBSIDIAN_VAULT_PATH=/Users/you/Documents/MyVault
